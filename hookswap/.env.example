# ---------------------------------------------------------------------------
# HookSwap routing-api .env example
# Copy to the routing-api repo root as `.env` and fill in real values.
# routing-api reads per-chain RPC as WEB3_RPC_<chainId>.
# ---------------------------------------------------------------------------

# --- Required: per-chain RPC URLs (v2 + v3 quoting, on-chain static pools) ---
WEB3_RPC_11155111=            # Sepolia   (11155111) - e.g. https://sepolia.infura.io/v3/<key>
WEB3_RPC_999=https://rpc.hyperliquid.xyz/evm   # HyperEVM (999)
WEB3_RPC_4663=                # Robinhood (4663) - Robinhood chain RPC (https://rpc.mainnet.chain.robinhood.com)
WEB3_RPC_4326=https://mainnet.megaeth.com/rpc  # MegaETH (4326)
WEB3_RPC_57073=https://rpc-gel.inkonchain.com  # Ink (57073)

# --- Optional: subgraph URLs (TODO) ---------------------------------------
# Not required today: HookSwap chains use SOR's on-chain Static*SubgraphProvider
# fallback (no subgraph). Fill these only if you deploy subgraphs AND register the
# chains in lib/cron/cache-config.ts (chainProtocols + v2/v3SubgraphUrlOverride).
SUBGRAPH_URL_11155111=        # TODO Sepolia v2/v3 subgraph
SUBGRAPH_URL_999=             # TODO HyperEVM v2/v3 subgraph
SUBGRAPH_URL_4663=            # TODO Robinhood v2/v3 subgraph
SUBGRAPH_URL_4326=            # TODO MegaETH v2/v3 subgraph
SUBGRAPH_URL_57073=           # TODO Ink v2/v3 subgraph

# --- Optional: Tenderly simulation (leave blank -> eth_estimateGas fallback) ---
TENDERLY_USER=
TENDERLY_PROJECT=
TENDERLY_ACCESS_KEY=
TENDERLY_NODE_API_KEY=

# --- Optional: subgraph query keys (only if using hosted subgraphs above) ---
ALCHEMY_QUERY_KEY=
ALCHEMY_QUERY_KEY_2=
GRAPH_BEARER_TOKEN=
GOLDSKY_BEARER_TOKEN=
GOLDSKY_API_KEY=

# --- Optional: Uniswap GraphQL token-fee fetch (falls back to on-chain) ---
GQL_URL=
GQL_H_ORGN=

# --- e2e / script helpers ---
# UNISWAP_ROUTING_API=https://<your-deployed-url>/   # used by scripts/get_quote.ts
# ARCHIVE_NODE_RPC=

# ---------------------------------------------------------------------------
# NOTE: the Foundry deploy kit (HookSwap/contracts/config/chains.json) uses a
# DIFFERENT RPC env-var convention: SEPOLIA_RPC_URL / HYPEREVM_RPC_URL /
# ROBINHOOD_RPC_URL. If you share one .env, set both conventions.
# ---------------------------------------------------------------------------
